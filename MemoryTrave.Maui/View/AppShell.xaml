<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MemoryTrave.Maui.View.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:view="clr-namespace:MemoryTrave.Maui.View"
    xmlns:viewModel="clr-namespace:MemoryTrave.Maui.ViewModel"
    xmlns:localization="using:MemoryTrave.Maui.Resources.Localization"
    x:DataType="viewModel:AppShellViewModel"
    TabBarTitleColor="Black"
    TabBarForegroundColor="Black"
    TabBarUnselectedColor="Gray">

    <TabBar>
        <Tab Title="{x:Static localization:Localization.Map}">
            <Tab.Icon>
                <FontImageSource Glyph="&#x1F4CD;"/>
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate view:MapPage}" />
        </Tab>
        
        <Tab Title="{x:Static localization:Localization.Profile}" 
             IsVisible="{Binding IsAuthorized}">
            <Tab.Icon>
                <FontImageSource Glyph="&#x1F464;"/>
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate view:ProfilePage}" />
        </Tab>
        
        <Tab Title="{x:Static localization:Localization.Settings}">
            <Tab.Icon>
                <FontImageSource Glyph="&#x2699;"/>
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate view:SettingsPage}" />
        </Tab>
    </TabBar>
    
</Shell>